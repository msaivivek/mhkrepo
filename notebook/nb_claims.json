				"spark.dynamicAllocation.enabled": "false",
				"spark.dynamicAllocation.minExecutors": "2",
				"spark.dynamicAllocation.maxExecutors": "2",
				"spark.autotune.trackingId": "07dcf7e7-8fb1-4b4e-8a3a-2d56cf54a82e"
			}
		},
		"metadata": {
			"saveOutput": true,
			"enableDebugMode": false,
			"kernelspec": {
				"name": "synapse_pyspark",
				"display_name": "Synapse PySpark"
			},
			"language_info": {
				"name": "python"
			},
			"a365ComputeOptions": {
				"id": "/subscriptions/69610fcb-7e3e-4c49-8e10-bc0fa4d67fe2/resourceGroups/RG_MHK/providers/Microsoft.Synapse/workspaces/ws-mhk/bigDataPools/mhksparkcluster",
				"name": "mhksparkcluster",
				"type": "Spark",
				"endpoint": "https://ws-mhk.dev.azuresynapse.net/livyApi/versions/2019-11-01-preview/sparkPools/mhksparkcluster",
				"auth": {
					"type": "AAD",
					"authResource": "https://dev.azuresynapse.net"
				},
				"sparkVersion": "3.5",
				"nodeCount": 3,
				"cores": 4,
				"memory": 28,
				"automaticScaleJobs": false
			},
			"sessionKeepAliveTimeout": 30
		},
		"cells": [
			{
				"cell_type": "code",
				"source": [
					"containername = \"filesysmhk\"\n",
					"storageaccount = \"sasynapsemhk\"\n",
					"sourcepath = \"raw/claims\"\n",
					"targetpath = \"staging/claims\"\n",
					"run_id = \"manual\""
				],
				"execution_count": null
			},
			{
				"cell_type": "code",
				"source": [
					"\n",
					"input_path = f'abfss://{containername}@{storageaccount}.dfs.core.windows.net/{sourcepath}.csv'"
				],
				"execution_count": null
			},
			{
				"cell_type": "code",
				"source": [
					"df = spark.read.option(\"header\",True).csv(input_path)\n",
					"\n",
					"df.show()"
				],
				"execution_count": null
			},
			{
				"cell_type": "code",
				"source": [
					"from pyspark.sql.functions import current_timestamp, lit, upper\n",
					"\n",
					"df2 = (\n",
					"    df\n",
					"    .dropDuplicates()\n",
					"    .fillna(\"NA\")\n",
					"    .withColumn(\"run_id\", lit(run_id))\n",
					"    .withColumn(\"load_date\", current_timestamp())\n",
					")\n",
					"\n",
					"df2.show()"
				],
				"execution_count": null
			},
			{
				"cell_type": "code",
				"source": [
					"from pyspark.sql.functions import when\n",
					"\n",
					"df2 = df2.withColumn(\n",
					"    \"claim_status\",\n",
					"    when(df2.claim_amount > 1000, \"HIGH\").otherwise(\"LOW\")\n",
					")"
				],
				"execution_count": null
			},
			{
				"cell_type": "code",
				"metadata": {
					"collapsed": false
				},
				"source": [
					"display(df2)"
				],
				"execution_count": null
			},
			{
				"cell_type": "code",
				"source": [
					"outputpath = f'abfss://{containername}@{storageaccount}.dfs.core.windows.net/{targetpath}'"
				],
				"execution_count": null
			},
			{
				"cell_type": "code",
				"source": [
					"df2.write.mode(\"overwrite\").parquet(outputpath)"
				],
				"execution_count": null
			}
		]
	}
}