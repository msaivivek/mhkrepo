		"cells": [
			{
				"cell_type": "code",
				"source": [
					"def get_param(name, default_value):\n",
					"    try:\n",
					"        return spark.conf.get(name)\n",
					"    except:\n",
					"        return default_value\n",
					"\n",
					"\n",
					"\n",
					"\n",
					"file_name   = get_param(\"file_name\", \"claims\")\n",
					"source_path = get_param(\"source_path\", \"filesysmhk/raw/claims\")\n",
					"target_path = get_param(\"target_path\", \"filesysmhk/staging/claims\")\n",
					"run_id      = get_param(\"run_id\", \"MANUAL_RUN\")\n",
					"\n",
					"\n",
					"print(file_name)\n",
					"print(source_path)\n",
					"print(target_path)\n",
					"print(run_id)"
				],
				"execution_count": null
			},
			{
				"cell_type": "code",
				"source": [
					"df = spark.read.option(\"header\",True).csv(input_path)\n",
					"\n",
					"df.show()"
				],
				"execution_count": 18
			},
			{
				"cell_type": "code",
				"source": [
					"from pyspark.sql.functions import current_timestamp, lit, upper\n",
					"\n",
					"df2 = (\n",
					"    df\n",
					"    .dropDuplicates()\n",
					"    .fillna(\"NA\")\n",
					"    .withColumn(\"run_id\", lit(run_id))\n",
					"    .withColumn(\"load_date\", current_timestamp())\n",
					")\n",
					"\n",
					"df2.show()"
				],
				"execution_count": 19
			},
			{
				"cell_type": "code",
				"source": [
					"from pyspark.sql.functions import when\n",
					"\n",
					"df2 = df2.withColumn(\n",
					"    \"claim_status\",\n",
					"    when(df2.claim_amount > 1000, \"HIGH\").otherwise(\"LOW\")\n",
					")"
				],
				"execution_count": 21
			},
			{
				"cell_type": "code",
				"metadata": {
					"collapsed": false
				},
				"source": [
					"display(df2)"
				],
				"execution_count": null
			},
			{
				"cell_type": "code",
				"source": [
					"df2.write.mode(\"overwrite\").parquet(output_path)"
				],
				"execution_count": 22
			}
		]
